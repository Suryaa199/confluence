<Window x:Class="InterviewCopilot.Windows.OverlayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Overlay" Height="300" Width="500" Topmost="True"
        WindowStyle="ToolWindow" Opacity="0.9" Background="#111111"
        AllowsTransparency="False" ResizeMode="CanResizeWithGrip"
        ShowInTaskbar="False">
    <Border Padding="8" CornerRadius="6" Background="#222">
        <StackPanel>
            <TextBlock Text="Answer (overlay)" FontWeight="Bold"/>
            <ScrollViewer x:Name="AnswerScroll"
                          VerticalScrollBarVisibility="Visible"
                          HorizontalScrollBarVisibility="Disabled"
                          Margin="0,4,0,0"
                          Background="#1A1A1A"
                          BorderBrush="#444"
                          BorderThickness="1">
                <TextBlock x:Name="AnswerText" TextWrapping="Wrap" Margin="4"/>
            </ScrollViewer>
        </StackPanel>
    </Border>
</Window>
