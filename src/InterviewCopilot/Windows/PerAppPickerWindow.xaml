<Window x:Class="InterviewCopilot.Windows.PerAppPickerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Per-App Picker" Height="400" Width="500" WindowStartupLocation="CenterOwner"
        Background="{DynamicResource Surface}" Foreground="#FFFFFF">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <StackPanel Orientation="Horizontal" Grid.Row="0">
            <Button Content="Refresh" Click="OnRefresh"/>
            <TextBlock Text="Selected:" Margin="8,0,0,0"/>
            <TextBlock x:Name="SelectedText"/>
        </StackPanel>
        <Grid Grid.Row="1">
            <Border BorderBrush="{StaticResource InputBorder}" BorderThickness="1" CornerRadius="4">
                <ListView x:Name="List" SelectionMode="Single">
                    <ListView.View>
                        <GridView>
                            <GridViewColumn Header="Device" DisplayMemberBinding="{Binding DeviceName}" Width="160"/>
                            <GridViewColumn Header="Process" DisplayMemberBinding="{Binding ProcessName}" Width="150"/>
                            <GridViewColumn Header="Title" DisplayMemberBinding="{Binding WindowTitle}" Width="220"/>
                            <GridViewColumn Header="Level" Width="60">
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <ProgressBar Minimum="0" Maximum="1" Value="{Binding Level}" Height="12"/>
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>
                        </GridView>
                    </ListView.View>
                </ListView>
            </Border>
            <TextBlock x:Name="EmptyText"
                       Text="No active sessions detected on any output device. Play audio on the device you plan to capture (Communications/System) and click Refresh."
                       Visibility="Collapsed"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"
                       TextWrapping="Wrap"
                       Margin="12"/>
        </Grid>
        <StackPanel Orientation="Horizontal" Grid.Row="2" HorizontalAlignment="Right" Margin="0,8,0,0">
            <Button Content="Use" Click="OnUse"/>
            <Button Content="Close" Margin="8,0,0,0" Click="OnClose"/>
        </StackPanel>
    </Grid>
</Window>
