<Window x:Class="InterviewCopilot.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:InterviewCopilot.ViewModels"
        mc:Ignorable="d"
        Title="Interview Copilot" Height="720" Width="1100"
        Topmost="True" WindowStartupLocation="CenterScreen">
    <!-- DataContext is assigned in code-behind to avoid XAML compile-time instantiation. -->
    <Grid Background="{DynamicResource Surface}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <DockPanel Grid.Row="0" Background="{DynamicResource SurfaceLow}" LastChildFill="False" Margin="0,0,0,0">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="Interview Copilot" Style="{StaticResource Title}" Margin="0,0,12,0"/>
                <TextBlock Text=" | " Margin="4,0"/>
                <TextBlock Text="{Binding ApiStatus}" VerticalAlignment="Center"/>
                <StackPanel Orientation="Horizontal" Margin="12,0,0,0" Visibility="{Binding OnboardingVisible, Converter={x:Static BooleanToVisibilityConverter.Instance}}">
                    <TextBox Width="220" Text="{Binding OpenAiKeyInput, UpdateSourceTrigger=PropertyChanged}"/>
                    <Button Content="Save Key" Command="{Binding SaveKeyCommand}"/>
                </StackPanel>
            </StackPanel>
            <ComboBox Width="140" ItemsSource="{Binding AudioSources}" SelectedItem="{Binding SelectedAudioSource}"/>
            <ComboBox Width="180" ItemsSource="{Binding AudioEndpoints}" SelectedItem="{Binding SelectedAudioEndpoint}" DisplayMemberPath="Name"/>
            <ComboBox Width="150" ItemsSource="{Binding DevicePreferences}" SelectedItem="{Binding SelectedDevicePreference}"/>
            <ComboBox Width="140" ItemsSource="{Binding SessionHints}" SelectedItem="{Binding SelectedSessionHint}"/>
            <Button Content="Per-App Picker" Command="{Binding OpenPerAppPickerCommand}"/>
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="8,0,0,0">
                <TextBlock Text="Level" VerticalAlignment="Center" Margin="0,0,6,0"/>
                <ProgressBar Width="120" Height="12" Minimum="0" Maximum="1" Value="{Binding Level}"/>
                <Rectangle Width="4" Height="12" Fill="{DynamicResource Primary}" Margin="6,0,0,0">
                    <Rectangle.LayoutTransform>
                        <ScaleTransform ScaleX="{Binding PeakLevel}"/>
                    </Rectangle.LayoutTransform>
                </Rectangle>
                <TextBlock Text="Endpoint:" Margin="12,0,0,0"/>
                <TextBlock Text="{Binding SelectedAudioEndpoint.Name}"/>
                <TextBlock Text=", Device:"/>
                <TextBlock Text="{Binding SelectedDevicePreference}"/>
                <Button Content="Test Levels" Margin="8,0,0,0" Padding="10,4" Command="{Binding TestLevelsCommand}"/>
            </StackPanel>
            <Button Content="{Binding ToggleCaptureLabel}" Style="{StaticResource PrimaryButton}" Command="{Binding ToggleCaptureCommand}"/>
            <Button Content="Overlay" Margin="4,0" Padding="12,4" Command="{Binding ToggleOverlayCommand}"/>
            <Button Content="Settings" Margin="4,0" Padding="12,4" Command="{Binding OpenSettingsCommand}"/>
        </DockPanel>

        <Grid Grid.Row="1" Margin="12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="220"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <!-- Sidebar -->
            <Border Grid.Column="0" Background="{DynamicResource SurfaceLow}" Padding="8">
                <StackPanel>
                    <TextBlock Text="Navigation" Style="{StaticResource Subtitle}"/>
                    <ToggleButton Style="{StaticResource SidebarToggle}" IsChecked="{Binding IsInterviewView}" Command="{Binding ShowInterviewCommand}" Content="Interview"/>
                    <ToggleButton Style="{StaticResource SidebarToggle}" IsChecked="{Binding IsCheatView}" Command="{Binding ShowCheatCommand}" Content="Cheat Sheet"/>
                    <ToggleButton Style="{StaticResource SidebarToggle}" IsChecked="{Binding IsStoriesView}" Command="{Binding ShowStoriesCommand}" Content="Stories"/>
                    <ToggleButton Style="{StaticResource SidebarToggle}" IsChecked="{Binding IsSettingsView}" Command="{Binding ShowSettingsCommand}" Content="Settings"/>
                    <TextBlock Text="Hotkeys: Alt+P overlay, Alt+C copy, Alt+G regen, Alt+S pause" TextWrapping="Wrap" Margin="0,12,0,0"/>
                </StackPanel>
            </Border>
            <Border Grid.ColumnSpan="2" Background="#22111111" CornerRadius="6" Padding="12" Visibility="{Binding OnboardingVisible, Converter={StaticResource BoolToVis}}">
                <StackPanel>
                    <TextBlock Text="Get Started" Style="{StaticResource Title}"/>
                    <TextBlock Text="Enter your OpenAI API key or switch to local providers in Settings." Margin="0,8,0,0"/>
                    <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                        <TextBox Width="280" Text="{Binding OpenAiKeyInput, UpdateSourceTrigger=PropertyChanged}"/>
                        <Button Content="Save Key" Command="{Binding SaveKeyCommand}"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                        <Button Content="Open Settings" Command="{Binding OpenSettingsCommand}"/>
                        <Button Content="Per-App Picker" Command="{Binding OpenPerAppPickerCommand}"/>
                    </StackPanel>
                </StackPanel>
            </Border>
            <Border Grid.Column="1" Background="{DynamicResource SurfaceVariant}" CornerRadius="6" Padding="8" Margin="0,0,8,0" Visibility="{Binding IsInterviewView, Converter={StaticResource BoolToVis}}">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <TextBlock Text="Question (live transcription)" Style="{StaticResource Subtitle}"/>
                        <TextBlock Text="{Binding LiveQuestion}" TextWrapping="Wrap" Margin="0,8,0,0"/>
                        <TextBlock Text="Follow-ups" Style="{StaticResource Subtitle}" Margin="0,16,0,0"/>
                        <ItemsControl ItemsSource="{Binding FollowUps}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="{DynamicResource ChipBg}" CornerRadius="12" Margin="0,4,8,4" Padding="8,4">
                                        <TextBlock Text="{Binding}"/>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                        </ItemsControl>
                    </StackPanel>
                </ScrollViewer>
            </Border>
            <Border Grid.Column="1" Background="{DynamicResource SurfaceVariant}" CornerRadius="6" Padding="8" Visibility="{Binding IsInterviewView, Converter={StaticResource BoolToVis}}">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <TextBlock Text="Answer (streaming)" Style="{StaticResource Subtitle}"/>
                        <TextBlock Text="{Binding LiveAnswer}" TextWrapping="Wrap" Margin="0,8,0,0"/>
                    </StackPanel>
                </ScrollViewer>
            </Border>

            <!-- Cheat Sheet View -->
            <Border Grid.Column="1" Background="{DynamicResource SurfaceVariant}" CornerRadius="6" Padding="8" Visibility="{Binding IsCheatView, Converter={StaticResource BoolToVis}}">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <TextBlock Text="Cheat Sheet" Style="{StaticResource Subtitle}"/>
                        <TextBlock Text="{Binding CheatSheetText}" TextWrapping="Wrap" Margin="0,8,0,0"/>
                    </StackPanel>
                </ScrollViewer>
            </Border>

            <!-- Stories View -->
            <Border Grid.Column="1" Background="{DynamicResource SurfaceVariant}" CornerRadius="6" Padding="8" Visibility="{Binding IsStoriesView, Converter={StaticResource BoolToVis}}">
                <StackPanel>
                    <TextBlock Text="Stories" Style="{StaticResource Subtitle}"/>
                    <StackPanel Orientation="Horizontal" Margin="0,8,0,8">
                        <TextBox Width="240" Text="{Binding StoryQuery, UpdateSourceTrigger=PropertyChanged}"/>
                        <Button Content="Search" Command="{Binding StorySearchCommand}"/>
                        <Button Content="Today" Command="{Binding SetFilterCommand}" CommandParameter="0" Margin="8,0,0,0"/>
                        <Button Content="7d" Command="{Binding SetFilterCommand}" CommandParameter="7"/>
                        <Button Content="30d" Command="{Binding SetFilterCommand}" CommandParameter="30"/>
                        <Button Content="Clear" Command="{Binding ClearFilterCommand}"/>
                    </StackPanel>
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <ListBox ItemsSource="{Binding StorySearchResults}"/>
                    </ScrollViewer>
                </StackPanel>
            </Border>

            <!-- Settings View redirect -->
            <Border Grid.Column="1" Background="{DynamicResource SurfaceVariant}" CornerRadius="6" Padding="8" Visibility="{Binding IsSettingsView, Converter={StaticResource BoolToVis}}">
                <StackPanel>
                    <TextBlock Text="Settings" Style="{StaticResource Subtitle}"/>
                    <TextBlock Text="Open the Settings window to edit preferences." Margin="0,8,0,8"/>
                    <Button Content="Open Settings" Command="{Binding OpenSettingsCommand}"/>
                </StackPanel>
            </Border>
        </Grid>

        <StatusBar Grid.Row="2">
            <StatusBarItem>
                <TextBlock Text="Audio: {Binding AudioStatus}"/>
            </StatusBarItem>
            <StatusBarItem>
                <TextBlock Text="ASR: {Binding AsrStatus}"/>
            </StatusBarItem>
            <StatusBarItem>
                <TextBlock Text="LLM: {Binding LlmStatus}"/>
            </StatusBarItem>
        </StatusBar>
    </Grid>

    <Window.InputBindings>
        <KeyBinding Modifiers="Alt" Key="P" Command="{Binding ToggleClickThroughCommand}"/>
        <KeyBinding Modifiers="Alt" Key="C" Command="{Binding CopyAnswerCommand}"/>
        <KeyBinding Modifiers="Alt" Key="G" Command="{Binding RegenerateCommand}"/>
        <KeyBinding Modifiers="Alt" Key="S" Command="{Binding PauseCommand}"/>
    </Window.InputBindings>
</Window>
