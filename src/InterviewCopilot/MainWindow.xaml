<Window x:Class="InterviewCopilot.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Interview Copilot" Height="720" Width="1100" MinWidth="900" MinHeight="640"
        UseLayoutRounding="True" SnapsToDevicePixels="True"
        WindowStartupLocation="CenterScreen">
    <Grid Background="{DynamicResource Surface}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Top bar -->
        <Border Grid.Row="0" Background="{DynamicResource SurfaceLow}" Padding="8">
            <StackPanel>
                <DockPanel LastChildFill="True">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" DockPanel.Dock="Left">
                        <TextBlock Text="Interview Copilot" Style="{StaticResource Title}" Margin="0,0,12,0"/>
                        <TextBlock Text=" | " Margin="4,0"/>
                        <TextBlock Text="{Binding ApiStatus}" VerticalAlignment="Center"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" DockPanel.Dock="Right">
                        <TextBox Style="{StaticResource {x:Type TextBox}}" Width="260"
                                 MinWidth="220"
                                 Margin="0,0,8,0"
                                 TextWrapping="NoWrap"
                                 ScrollViewer.HorizontalScrollBarVisibility="Auto"
                                 Text="{Binding OpenAiKeyInput, UpdateSourceTrigger=PropertyChanged}"
                                 ToolTip="Paste your OpenAI API key"/>
                        <Button Content="{Binding TestKeyLabel}" Command="{Binding TestKeyCommand}" IsEnabled="{Binding IsTestingKey, Converter={StaticResource InverseBool}}"/>
                        <Button Content="Save Key" Command="{Binding SaveKeyCommand}"/>
                    </StackPanel>
                </DockPanel>
                <TextBlock Text="{Binding KeyStatusMessage}" Margin="0,4,0,0" Foreground="{DynamicResource Primary}" TextWrapping="Wrap"/>
                <StackPanel Orientation="Horizontal" Margin="0,4,0,0" Visibility="{Binding OnboardingVisible, Converter={StaticResource BoolToVis}}">
                    <TextBlock Text="OpenAI key missing. Enter it above to enable streaming answers."/>
                </StackPanel>
                <ScrollViewer Margin="0,8,0,0" HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Disabled">
                    <WrapPanel>
                        <StackPanel MinWidth="170" Margin="0,0,12,12">
                            <TextBlock Text="Provider Mode" FontWeight="SemiBold" Margin="0,0,0,4"/>
                            <ComboBox Style="{StaticResource {x:Type ComboBox}}" ItemsSource="{Binding ProviderProfiles}" SelectedItem="{Binding SelectedProviderProfile}"/>
                        </StackPanel>
                        <StackPanel MinWidth="150" Margin="0,0,12,12">
                            <TextBlock Text="LLM Provider" FontWeight="SemiBold" Margin="0,0,0,4"/>
                            <ComboBox Style="{StaticResource {x:Type ComboBox}}" ItemsSource="{Binding LlmProviders}" SelectedItem="{Binding SelectedLlmProvider}"/>
                        </StackPanel>
                        <StackPanel MinWidth="150" Margin="0,0,12,12">
                            <TextBlock Text="ASR Provider" FontWeight="SemiBold" Margin="0,0,0,4"/>
                            <ComboBox Style="{StaticResource {x:Type ComboBox}}" ItemsSource="{Binding AsrProviders}" SelectedItem="{Binding SelectedAsrProvider}"/>
                        </StackPanel>
                        <StackPanel MinWidth="160" Margin="0,0,12,12">
                            <TextBlock Text="Quick Preset" FontWeight="SemiBold" Margin="0,0,0,4"/>
                            <ComboBox Style="{StaticResource {x:Type ComboBox}}" SelectedValuePath="Content" SelectedValue="{Binding SelectedPreset}">
                                <ComboBoxItem Content="Cloud"/>
                                <ComboBoxItem Content="Local Low-Latency"/>
                                <ComboBoxItem Content="Safe"/>
                            </ComboBox>
                        </StackPanel>
                        <StackPanel MinWidth="150" Margin="0,0,12,12">
                            <TextBlock Text="Audio Source" FontWeight="SemiBold" Margin="0,0,0,4"/>
                            <ComboBox Style="{StaticResource {x:Type ComboBox}}" ItemsSource="{Binding AudioSources}" SelectedItem="{Binding SelectedAudioSource}" ToolTip="Audio Source (PerApp/System/Microphone)"/>
                        </StackPanel>
                        <StackPanel MinWidth="230" Margin="0,0,12,12">
                            <TextBlock Text="Audio Endpoint" FontWeight="SemiBold" Margin="0,0,0,4"/>
                            <ComboBox Style="{StaticResource {x:Type ComboBox}}" ItemsSource="{Binding AudioEndpoints}" SelectedItem="{Binding SelectedAudioEndpoint}" DisplayMemberPath="Name" ToolTip="Audio Endpoint (Default/Communications or specific device)"/>
                        </StackPanel>
                        <StackPanel MinWidth="150" Margin="0,0,12,12">
                            <TextBlock Text="Device Preference" FontWeight="SemiBold" Margin="0,0,0,4"/>
                            <ComboBox Style="{StaticResource {x:Type ComboBox}}" ItemsSource="{Binding DevicePreferences}" SelectedItem="{Binding SelectedDevicePreference}" ToolTip="Device Preference (Default vs Communications)"/>
                        </StackPanel>
                        <StackPanel MinWidth="150" Margin="0,0,12,12">
                            <TextBlock Text="Session Hint" FontWeight="SemiBold" Margin="0,0,0,4"/>
                            <ComboBox Style="{StaticResource {x:Type ComboBox}}" ItemsSource="{Binding SessionHints}" SelectedItem="{Binding SelectedSessionHint}" ToolTip="Helps prioritize the meeting app process"/>
                        </StackPanel>
                        <StackPanel MinWidth="220" Margin="0,0,12,12">
                            <TextBlock Text="Live Cue (next answer)" FontWeight="SemiBold" Margin="0,0,0,4"/>
                            <StackPanel Orientation="Horizontal">
                                <TextBox Style="{StaticResource {x:Type TextBox}}" Width="160"
                                         Text="{Binding LiveCueText, UpdateSourceTrigger=PropertyChanged}"
                                         ToolTip="Short hint to mention in the next response"/>
                                <Button Content="Inject" Command="{Binding ApplyLiveCueCommand}" Margin="6,0,0,0"/>
                            </StackPanel>
                        </StackPanel>
                        <ToggleButton Style="{StaticResource {x:Type ToggleButton}}" Content="Coach Audio"
                                      Margin="0,0,12,12"
                                      Command="{Binding ToggleSpeakAnswersCommand}"
                                      CommandParameter="{Binding IsChecked, RelativeSource={RelativeSource Self}}"
                                      IsChecked="{Binding SpeakAnswersEnabled}"
                                      ToolTip="Speak the generated answers aloud after each response."/>
                        <Button Content="Auto (Live)"
                                Margin="0,0,12,12"
                                Command="{Binding AutoConfigureCommand}"
                                ToolTip="Auto-configure low-latency interview settings."/>
                        <StackPanel Margin="0,0,12,12">
                            <TextBlock Text="Audio Meter" FontWeight="SemiBold" Margin="0,0,0,4"/>
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <ProgressBar Width="140" Height="12" Minimum="0" Maximum="1" Value="{Binding Level}"/>
                                <Rectangle Width="4" Height="12" Fill="{DynamicResource Primary}" Margin="6,0,0,0">
                                    <Rectangle.LayoutTransform>
                                        <ScaleTransform ScaleX="{Binding PeakLevel}"/>
                                    </Rectangle.LayoutTransform>
                                </Rectangle>
                            </StackPanel>
                            <Button Content="Test Levels" Command="{Binding TestLevelsCommand}" Margin="0,6,0,0"/>
                        </StackPanel>
                        <Button Content="Per-App Picker" Command="{Binding OpenPerAppPickerCommand}" Margin="0,0,12,12"/>
                        <Button Content="Overlay" Command="{Binding ToggleOverlayCommand}" Margin="0,0,12,12"/>
                        <Button Content="Settings" Command="{Binding OpenSettingsCommand}" Margin="0,0,12,12"/>
                        <Button Content="{Binding ToggleCaptureLabel}" Style="{StaticResource PrimaryButton}" Command="{Binding ToggleCaptureCommand}" Margin="0,0,12,12"/>
                    </WrapPanel>
                </ScrollViewer>
            </StackPanel>
        </Border>

        <!-- Center content -->
        <Grid Grid.Row="1" Margin="12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" MinWidth="220"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Sidebar -->
            <Border Grid.Column="0" Background="{DynamicResource SurfaceLow}" Padding="8">
                <StackPanel>
                    <TextBlock Text="Navigation" Style="{StaticResource Subtitle}"/>
                    <ToggleButton Style="{StaticResource SidebarToggle}" IsChecked="{Binding IsInterviewView}" Command="{Binding ShowInterviewCommand}" Content="Interview"/>
                    <ToggleButton Style="{StaticResource SidebarToggle}" IsChecked="{Binding IsCheatView}" Command="{Binding ShowCheatCommand}" Content="Cheat Sheet"/>
                    <ToggleButton Style="{StaticResource SidebarToggle}" IsChecked="{Binding IsStoriesView}" Command="{Binding ShowStoriesCommand}" Content="Stories"/>
                    <ToggleButton Style="{StaticResource SidebarToggle}" IsChecked="{Binding IsSettingsView}" Command="{Binding ShowSettingsCommand}" Content="Settings"/>
                    <ToggleButton Style="{StaticResource SidebarToggle}" IsChecked="{Binding IsTelemetryView}" Command="{Binding ShowTelemetryCommand}" Content="Telemetry"/>
                    <TextBlock Text="Hotkeys: Alt+P overlay, Alt+C copy, Alt+G regen, Alt+S pause" TextWrapping="Wrap" Margin="0,12,0,0"/>
                </StackPanel>
            </Border>

            <!-- Onboarding notice -->
            <Border Grid.ColumnSpan="2" Background="#22111111" CornerRadius="6" Padding="12" Visibility="{Binding OnboardingVisible, Converter={StaticResource BoolToVis}}">
                <StackPanel>
                    <TextBlock Text="OpenAI key missing" Style="{StaticResource Subtitle}"/>
                    <TextBlock Text="Enter your API key above or switch to Local providers in Settings." TextWrapping="Wrap" Margin="0,6,0,0"/>
                </StackPanel>
            </Border>

            <!-- Interview View -->
            <Border Grid.Column="1" Background="{DynamicResource SurfaceVariant}" CornerRadius="6" Padding="8" Visibility="{Binding IsInterviewView, Converter={StaticResource BoolToVis}}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <StackPanel Grid.Row="0" Orientation="Vertical" Margin="0,0,0,8">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="Transcript (question)" Style="{StaticResource Subtitle}"/>
                            <Button Content="Copy" Command="{Binding CopyTranscriptCommand}" Margin="8,0,0,0"/>
                            <Button Content="{Binding ToggleCaptureLabel}" Style="{StaticResource PrimaryButton}" Command="{Binding ToggleCaptureCommand}" Margin="12,0,0,0"/>
                        </StackPanel>
                        <Grid>
                            <Border BorderBrush="{StaticResource InputBorder}" BorderThickness="1">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <TextBlock Text="{Binding LiveQuestion}" TextWrapping="Wrap"/>
                </ScrollViewer>
                            </Border>
                            <TextBlock Text="Start Listening to populate transcript..." Foreground="#999" HorizontalAlignment="Center" VerticalAlignment="Center">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding LiveQuestion}" Value="">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Grid>
                    </StackPanel>
                    <StackPanel Grid.Row="1">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="Answer" Style="{StaticResource Subtitle}"/>
                            <ProgressBar Width="60" Height="6" Margin="8,0,0,0" IsIndeterminate="True" Visibility="{Binding IsAnswerStreaming, Converter={StaticResource BoolToVis}}"/>
                            <ToggleButton Margin="8,0,0,0"
                                          Command="{Binding ToggleSpeakAnswersCommand}"
                                          CommandParameter="{Binding IsChecked, RelativeSource={RelativeSource Self}}"
                                          IsChecked="{Binding SpeakAnswersEnabled}">
                                <ToggleButton.Style>
                                    <Style TargetType="ToggleButton" BasedOn="{StaticResource {x:Type ToggleButton}}">
                                        <Setter Property="Content" Value="Enable TTS"/>
                                        <Style.Triggers>
                                            <Trigger Property="IsChecked" Value="True">
                                                <Setter Property="Content" Value="Mute TTS"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </ToggleButton.Style>
                            </ToggleButton>
                        </StackPanel>
                        <Grid>
                            <Border BorderBrush="{StaticResource InputBorder}" BorderThickness="1">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <TextBlock Text="{Binding LiveAnswer}" TextWrapping="Wrap"/>
                </ScrollViewer>
                            </Border>
                            <TextBlock Text="Answer will appear here..." Foreground="#999" HorizontalAlignment="Center" VerticalAlignment="Center">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding LiveAnswer}" Value="">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Grid>
                    </StackPanel>
                    <StackPanel Grid.Row="2" Orientation="Vertical" Margin="0,8,0,0">
                        <TextBlock Text="Follow-ups" Style="{StaticResource Subtitle}"/>
                        <ItemsControl ItemsSource="{Binding FollowUps}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Button Background="{DynamicResource ChipBg}" BorderThickness="0" Padding="6" Margin="4,4,0,0" Command="{Binding DataContext.TakeFollowUpCommand, RelativeSource={RelativeSource AncestorType=Window}}" CommandParameter="{Binding}">
                                        <TextBlock Text="{Binding}"/>
                                    </Button>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                            <Button Content="Regenerate" Command="{Binding RegenerateCommand}"/>
                            <Button Content="Copy" Command="{Binding CopyAnswerCommand}"/>
                        </StackPanel>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Cheat Sheet View -->
            <Border Grid.Column="1" Background="{DynamicResource SurfaceVariant}" CornerRadius="6" Padding="8" Visibility="{Binding IsCheatView, Converter={StaticResource BoolToVis}}">
                <StackPanel>
                    <TextBlock Text="Cheat Sheet" Style="{StaticResource Subtitle}"/>
                    <Grid>
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <TextBlock Text="{Binding CheatSheetText}" TextWrapping="Wrap"/>
                        </ScrollViewer>
                        <TextBlock Text="Generate a Cheat Sheet from Settings to see content here." Foreground="#999" HorizontalAlignment="Center" VerticalAlignment="Center">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding CheatSheetText}" Value="">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- Stories View -->
            <Border Grid.Column="1" Background="{DynamicResource SurfaceVariant}" CornerRadius="6" Padding="8" Visibility="{Binding IsStoriesView, Converter={StaticResource BoolToVis}}">
                <StackPanel>
                    <TextBlock Text="Stories" Style="{StaticResource Subtitle}"/>
                    <StackPanel Orientation="Horizontal" Margin="0,8,0,8">
                        <TextBox Style="{StaticResource {x:Type TextBox}}" MinWidth="220" Text="{Binding StoryQuery, UpdateSourceTrigger=PropertyChanged}"/>
                        <Button Content="Search" Command="{Binding StorySearchCommand}"/>
                        <Button Content="Today" Command="{Binding SetFilterCommand}" CommandParameter="0" Margin="8,0,0,0"/>
                        <Button Content="7d" Command="{Binding SetFilterCommand}" CommandParameter="7"/>
                        <Button Content="30d" Command="{Binding SetFilterCommand}" CommandParameter="30"/>
                        <Button Content="Clear" Command="{Binding ClearFilterCommand}"/>
                    </StackPanel>
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <ListBox ItemsSource="{Binding StorySearchResults}"/>
                    </ScrollViewer>
                </StackPanel>
            </Border>

            <!-- Settings View redirect -->
            <Border Grid.Column="1" Background="{DynamicResource SurfaceVariant}" CornerRadius="6" Padding="8" Visibility="{Binding IsSettingsView, Converter={StaticResource BoolToVis}}">
                <StackPanel>
                    <TextBlock Text="Settings" Style="{StaticResource Subtitle}"/>
                    <TextBlock Text="Open the Settings window to edit preferences." Margin="0,8,0,8"/>
                    <Button Content="Open Settings" Command="{Binding OpenSettingsCommand}"/>
                </StackPanel>
            </Border>

            <!-- Telemetry View -->
            <Border Grid.Column="1" Background="{DynamicResource SurfaceVariant}" CornerRadius="6" Padding="8" Visibility="{Binding IsTelemetryView, Converter={StaticResource BoolToVis}}">
                <StackPanel>
                    <TextBlock Text="Session Telemetry" Style="{StaticResource Subtitle}"/>
                    <TextBlock Text="{Binding LogFilePath, StringFormat=Log file: {0}}" Margin="0,4,0,4" Foreground="#AAA" TextWrapping="Wrap"/>
                    <ListView ItemsSource="{Binding TelemetryEntries}" Margin="0,8,0,0">
                        <ListView.View>
                            <GridView>
                                <GridViewColumn Header="Time" Width="140" DisplayMemberBinding="{Binding Timestamp}"/>
                                <GridViewColumn Header="Category" Width="100" DisplayMemberBinding="{Binding Category}"/>
                                <GridViewColumn Header="Persona" Width="80" DisplayMemberBinding="{Binding Persona}"/>
                                <GridViewColumn Header="Words" Width="60" DisplayMemberBinding="{Binding WordCount}"/>
                                <GridViewColumn Header="Retry" Width="60" DisplayMemberBinding="{Binding NeededRetry}"/>
                                <GridViewColumn Header="Question" Width="200" DisplayMemberBinding="{Binding Question}"/>
                            </GridView>
                        </ListView.View>
                    </ListView>
                </StackPanel>
            </Border>
        </Grid>

        <!-- Status bar -->
        <StatusBar Grid.Row="2">
            <StatusBarItem>
                <TextBlock>
                    <Run Text="Audio: "/>
                    <Run Text="{Binding AudioStatus}"/>
                </TextBlock>
            </StatusBarItem>
            <StatusBarItem>
                <TextBlock>
                    <Run Text="ASR: "/>
                    <Run Text="{Binding AsrStatus}" Foreground="{Binding AsrStatus, Converter={StaticResource StatusToBrush}}"/>
                </TextBlock>
            </StatusBarItem>
            <StatusBarItem>
                <TextBlock>
                    <Run Text="LLM: "/>
                    <Run Text="{Binding LlmStatus}" Foreground="{Binding LlmStatus, Converter={StaticResource StatusToBrush}}"/>
                </TextBlock>
            </StatusBarItem>
            <StatusBarItem>
                <TextBlock Text="{Binding VadStatus}"/>
            </StatusBarItem>
        </StatusBar>
    </Grid>

    <!-- Hotkeys -->
    <Window.InputBindings>
        <KeyBinding Modifiers="Alt" Key="P" Command="{Binding ToggleClickThroughCommand}"/>
        <KeyBinding Modifiers="Alt" Key="C" Command="{Binding CopyAnswerCommand}"/>
        <KeyBinding Modifiers="Alt" Key="G" Command="{Binding RegenerateCommand}"/>
        <KeyBinding Modifiers="Alt" Key="S" Command="{Binding PauseCommand}"/>
    </Window.InputBindings>
</Window>
