<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Style TargetType="Window">
        <Setter Property="Background" Value="{DynamicResource Surface}"/>
        <Setter Property="Foreground" Value="#EFEFEF"/>
    </Style>
    <Style TargetType="Border">
        <Setter Property="SnapsToDevicePixels" Value="True"/>
    </Style>

    <!-- Dark theme for inputs -->
    <!-- Increase contrast for better readability -->
    <SolidColorBrush x:Key="InputBg" Color="#25262A"/>
    <SolidColorBrush x:Key="InputBorder" Color="#5A5F66"/>
    <SolidColorBrush x:Key="InputFg" Color="#FAFAFA"/>

    <!-- Default Button style consolidated; avoid duplicate default style definitions -->

    <Style x:Key="PrimaryButton" TargetType="Button">
        <Setter Property="Foreground" Value="#000000"/>
        <Setter Property="Background" Value="{DynamicResource Primary}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource Primary}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding" Value="12,8"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Margin" Value="8,0,0,0"/>
    </Style>

    <Style TargetType="TextBox">
        <Setter Property="Foreground" Value="{StaticResource InputFg}"/>
        <Setter Property="Background" Value="{StaticResource InputBg}"/>
        <Setter Property="BorderBrush" Value="{StaticResource InputBorder}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding" Value="6,4"/>
    </Style>
    <Style TargetType="PasswordBox">
        <Setter Property="Foreground" Value="{StaticResource InputFg}"/>
        <Setter Property="Background" Value="{StaticResource InputBg}"/>
        <Setter Property="BorderBrush" Value="{StaticResource InputBorder}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding" Value="6,4"/>
    </Style>
    <Style TargetType="ComboBox">
        <Setter Property="Foreground" Value="{StaticResource InputFg}"/>
        <Setter Property="Background" Value="{StaticResource InputBg}"/>
        <Setter Property="BorderBrush" Value="{StaticResource InputBorder}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding" Value="6,4"/>
        <Setter Property="Height" Value="28"/>
        <Setter Property="Margin" Value="6,0,0,0"/>
        <Setter Property="SnapsToDevicePixels" Value="True"/>
    </Style>
    <Style TargetType="ComboBoxItem">
        <Setter Property="Foreground" Value="{StaticResource InputFg}"/>
        <Setter Property="Background" Value="{StaticResource InputBg}"/>
        <Setter Property="Padding" Value="6,4"/>
        <Setter Property="SnapsToDevicePixels" Value="True"/>
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="#33363A"/>
            </Trigger>
            <Trigger Property="IsSelected" Value="True">
                <Setter Property="Background" Value="{DynamicResource Primary}"/>
                <Setter Property="Foreground" Value="#000"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- Compact button height -->
    <Style TargetType="Button">
        <Setter Property="Foreground" Value="#EFEFEF"/>
        <Setter Property="Background" Value="#2D3036"/>
        <Setter Property="BorderBrush" Value="{StaticResource InputBorder}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding" Value="10,6"/>
        <Setter Property="Margin" Value="6,0,0,0"/>
        <Setter Property="Height" Value="28"/>
    </Style>
    <Style TargetType="ListBox">
        <Setter Property="Foreground" Value="{StaticResource InputFg}"/>
        <Setter Property="Background" Value="{StaticResource InputBg}"/>
        <Setter Property="BorderBrush" Value="{StaticResource InputBorder}"/>
        <Setter Property="BorderThickness" Value="1"/>
    </Style>

    <!-- Dark ListView + headers + row separators -->
    <Style TargetType="ListView">
        <Setter Property="Foreground" Value="{StaticResource InputFg}"/>
        <Setter Property="Background" Value="{StaticResource InputBg}"/>
        <Setter Property="BorderBrush" Value="{StaticResource InputBorder}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="SnapsToDevicePixels" Value="True"/>
        <Setter Property="ScrollViewer.CanContentScroll" Value="True"/>
        <Setter Property="AlternationCount" Value="2"/>
        <Setter Property="ItemContainerStyle">
            <Setter.Value>
                <Style TargetType="ListViewItem">
                    <Setter Property="Foreground" Value="{StaticResource InputFg}"/>
                    <Setter Property="Background" Value="#2A2A2E"/>
                    <Setter Property="BorderBrush" Value="#3C3F44"/>
                    <Setter Property="BorderThickness" Value="0,0,0,1"/>
                    <Style.Triggers>
                        <Trigger Property="ItemsControl.AlternationIndex" Value="1">
                            <Setter Property="Background" Value="#26292E"/>
                        </Trigger>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter Property="Background" Value="#3A4048"/>
                            <Setter Property="BorderBrush" Value="{DynamicResource Primary}"/>
                            <Setter Property="BorderThickness" Value="1"/>
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="GridViewColumnHeader">
        <Setter Property="Foreground" Value="#E0E0E0"/>
        <Setter Property="Background" Value="#2A2A2E"/>
        <Setter Property="BorderBrush" Value="#444444"/>
        <Setter Property="BorderThickness" Value="0,0,0,1"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Padding" Value="6,4"/>
    </Style>

    <!-- Sidebar toggle style -->
    <Style x:Key="SidebarToggle" TargetType="ToggleButton">
        <Setter Property="Foreground" Value="#EFEFEF"/>
        <Setter Property="Background" Value="#1F1F22"/>
        <Setter Property="BorderBrush" Value="#3A3A3F"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding" Value="8,6"/>
        <Setter Property="Margin" Value="0,4,0,0"/>
        <Setter Property="HorizontalContentAlignment" Value="Left"/>
        <Style.Triggers>
            <Trigger Property="IsChecked" Value="True">
                <Setter Property="Background" Value="{DynamicResource Primary}"/>
                <Setter Property="Foreground" Value="#000"/>
                <Setter Property="BorderBrush" Value="{DynamicResource Primary}"/>
            </Trigger>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="BorderBrush" Value="{DynamicResource Primary}"/>
            </Trigger>
        </Style.Triggers>
    </Style>
</ResourceDictionary>
